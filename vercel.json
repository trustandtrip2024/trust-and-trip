{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/price-drops",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cart-abandonment",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/review-request",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/escalate-stale-leads",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/founder-digest",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/refresh-creatives",
      "schedule": "0 4 * * 1"
    }
  ]
}
